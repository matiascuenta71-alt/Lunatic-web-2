# Environment Variables for Lunatic Community Web
# Do not commit actual secrets to this file.

# Port to bind the server (defaults to 3000)
PORT=3000

# Environment mode (development/production)
NODE_ENV=development

# Control plane toggle for Hot Module Replacement in development
DISABLE_HMR=true

# Gemini API Key (if needed for future AI features)
GEMINI_API_KEY=

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

